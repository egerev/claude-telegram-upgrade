+async function handleCliCommand(ctx: Context, text: string): Promise<boolean> {
+  // Strip @botusername suffix that Telegram appends to commands
+  const trimmed = text.trim().replace(/@\S+/, '')
+  // Check if this is a CLI command we handle
+  const cmdKey = Object.keys(CLI_COMMANDS).find(cmd => trimmed === cmd || trimmed.startsWith(cmd + ' '))
+  if (!cmdKey) return false
+
+  const session = await getTmuxSession()
+  if (!session) {
+    await ctx.reply('Not running in tmux — cannot execute CLI commands remotely.').catch(() => {})
+    return true
+  }
+
+  // /status is handled entirely in the bot — no tmux send-keys
+  if (cmdKey === '/dash') {
+    try {
+      const status = await buildStatusMessage(session)
+      await ctx.reply(status).catch(() => {})
+    } catch (e: any) {
+      await ctx.reply(`Status error: ${e.message}`).catch(() => {})
+    }
+    return true
+  }
+
+  try {
+    // Capture tmux state before command
+    const chat_id = String(ctx.chat!.id)
+    let beforeLines = 0
+    try {
+      const before = await runAsync('tmux', ['capture-pane', '-t', session, '-p'])
+      beforeLines = before.split('\n').length
+    } catch {}
+
+    // Send the command as keystrokes to the tmux session
+    await runAsync('tmux', ['send-keys', '-t', session, trimmed, 'Enter'])
+
+    // React to confirm
+    const msgId = ctx.message?.message_id
+    if (msgId != null) {
+      void bot.api.setMessageReaction(chat_id, msgId, [
+        { type: 'emoji', emoji: '👍' as ReactionTypeEmoji['emoji'] },
+      ]).catch(() => {})
+    }
+
+    // Wait for command to execute, then capture new output
+    await new Promise(r => setTimeout(r, 3000))
+    try {
+      const after = await runAsync('tmux', ['capture-pane', '-t', session, '-p'])
+      const afterLines = after.split('\n')
+      const newOutput = afterLines.slice(beforeLines).join('\n').trim()
+      if (newOutput) {
+        const clean = newOutput.replace(/\x1b\[[0-9;]*[a-zA-Z]/g, '').replace(/[─━═│┃┌┐└┘├┤┬┴┼╌╍]/g, '').trim()
+        if (clean && clean.length > 1) {
+          await bot.api.sendMessage(chat_id, `${trimmed}\n\n${clean.slice(0, 4000)}`).catch(() => {})
+        } else {
+          await ctx.reply(`✅ ${trimmed}`).catch(() => {})
+        }
+      } else {
+        await ctx.reply(`✅ ${trimmed}`).catch(() => {})
+      }
+    } catch {
+      await ctx.reply(`✅ ${trimmed}`).catch(() => {})
+    }
+  } catch (e: any) {
+    await ctx.reply(`Failed to execute: ${e.message}`).catch(() => {})
+  }
+  return true
+}
