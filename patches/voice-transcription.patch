+/**
+ * Build a rich status dashboard for Telegram from Claude Code status data.
+ * Reads ~/.claude/data/last_status.json (written by status_line.py).
+ */
+async function buildStatusMessage(session: string): Promise<string> {
+  const lines: string[] = []
+  lines.push(`📊 ${session}`)
+  lines.push('')
+
+  // Read status data dumped by status_line.py
+  let data: any = null
+  try {
+    const statusPath = join(process.env.HOME ?? '/home/ubuntu', '.claude', 'data', 'last_status.json')
+    data = JSON.parse(readFileSync(statusPath, 'utf8'))
+  } catch {}
+
+  if (data) {
+    // Model
+    const model = data.model?.display_name ?? 'Claude'
+    const cleanModel = model.includes('(') ? model.slice(0, model.indexOf('(')).trim() : model
+    lines.push(`🤖 ${cleanModel}`)
+
+    // Context window
+    const ctx = data.context_window ?? {}
+    const usedPct = Math.round(ctx.used_percentage ?? 0)
+    const windowSize = ctx.context_window_size ?? 1000000
+    const windowLabel = windowSize >= 1000000 ? `${windowSize / 1000000}M` : `${windowSize / 1000}K`
+    lines.push(`📐 Context: ${windowLabel} ${tgBar(usedPct)} ${usedPct}%`)
+
+    // Tokens
+    const current = ctx.current_usage ?? {}
+    const inputTokens = (current.input_tokens ?? 0) + (current.cache_creation_input_tokens ?? 0) + (current.cache_read_input_tokens ?? 0)
+    const outputTokens = current.output_tokens ?? 0
+    const fmtTok = (n: number) => n < 1000 ? String(n) : n < 10000 ? `${(n/1000).toFixed(1)}k` : n < 1000000 ? `${Math.round(n/1000)}k` : `${(n/1000000).toFixed(1)}M`
+    lines.push(`📝 In: ${fmtTok(inputTokens)} · Out: ${fmtTok(outputTokens)}`)
+
+    // Cache hit %
+    const cacheRead = current.cache_read_input_tokens ?? 0
+    const cacheTotal = (current.input_tokens ?? 0) + (current.cache_creation_input_tokens ?? 0) + cacheRead
+    if (cacheTotal > 0 && cacheRead > 0) {
+      const hitPct = Math.round((cacheRead / cacheTotal) * 100)
+      lines.push(`💾 Cache: ${hitPct}%`)
+    }
+
+    // Session duration
+    const sessionId = data.session_id ?? ''
+    if (sessionId) {
+      try {
+        const sessDir = join(process.env.HOME ?? '/home/ubuntu', '.claude', 'data', 'sessions')
+        const sessFile = join(sessDir, `${sessionId}.json`)
+        const sessData = JSON.parse(readFileSync(sessFile, 'utf8'))
+        if (sessData.created_at) {
+          const dur = (Date.now() - new Date(sessData.created_at).getTime()) / 1000
+          lines.push(`⏱ Session: ${fmtDuration(dur)}`)
+        }
+      } catch {}
+    }
+
+    // Rate limits
+    const rateLimits = data.rate_limits ?? {}
+    const fiveHour = rateLimits.five_hour ?? {}
+    const sevenDay = rateLimits.seven_day ?? {}
+
+    if (fiveHour.used_percentage != null) {
+      const pct = Math.round(fiveHour.used_percentage)
+      let resetStr = ''
+      if (fiveHour.resets_at) {
+        const resetIn = fiveHour.resets_at - Date.now() / 1000
+        if (resetIn > 0) resetStr = ` ↻${fmtDuration(resetIn)}`
+      }
+      lines.push(`⚡ 5h: ${tgBar(pct)} ${pct}%${resetStr}`)
+    }
+
+    if (sevenDay.used_percentage != null) {
+      const pct = Math.round(sevenDay.used_percentage)
+      let resetStr = ''
+      if (sevenDay.resets_at) {
+        const resetIn = sevenDay.resets_at - Date.now() / 1000
+        if (resetIn > 0) resetStr = ` ↻${fmtDuration(resetIn)}`
+      }
+      lines.push(`📅 7d: ${tgBar(pct)} ${pct}%${resetStr}`)
+    }
+  } else {
+    lines.push('No status data yet — send a few messages first')
+  }
+
+  return lines.join('\n')
+}
