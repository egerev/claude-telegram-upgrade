+/**
+ * Find the tmux session name for this process by walking the process tree.
+ * bun(server.ts) → bun(run) → claude → bash(pane) → tmux
+ * Returns session name or null if not running in tmux.
+ */
+let _tmuxSession: string | null | undefined
+async function getTmuxSession(): Promise<string | null> {
+  if (_tmuxSession !== undefined) return _tmuxSession
+  try {
+    // Get all tmux panes with their PIDs
+    const panes = await runAsync('tmux', ['list-panes', '-a', '-F', '#{pane_pid} #{session_name}'])
+    const paneMap = new Map<string, string>()
+    for (const line of panes.trim().split('\n')) {
+      const [pid, name] = line.split(' ', 2)
+      if (pid && name) paneMap.set(pid, name)
+    }
+    // Walk up from current process to find a PID that matches a tmux pane
+    let current = String(process.pid)
+    for (let i = 0; i < 8; i++) {
+      if (paneMap.has(current)) {
+        _tmuxSession = paneMap.get(current)!
+        return _tmuxSession
+      }
+      const ppid = await runAsync('ps', ['-o', 'ppid=', '-p', current])
+      current = ppid.trim()
+      if (!current || current === '1') break
+    }
+  } catch {}
+  _tmuxSession = null
+  return null
+}
