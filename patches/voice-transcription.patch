+const CLI_COMMANDS: Record<string, { description: string; aliases?: string[] }> = {
+  '/compact': { description: 'Compress conversation context' },
+  '/clear': { description: 'Clear conversation and start fresh' },
+  '/dash': { description: 'Show session dashboard' },
+  '/model': { description: 'Switch model (e.g. /model opus)', aliases: ['/model sonnet', '/model opus', '/model haiku'] },
+  '/effort': { description: 'Set effort level (e.g. /effort high)', aliases: ['/effort low', '/effort medium', '/effort high'] },
+}
