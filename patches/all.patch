 const INBOX_DIR = join(STATE_DIR, 'inbox')
+const PID_FILE = join(STATE_DIR, '.server.pid')
+const TOKEN_HASH = createHash('sha256').update(TOKEN).digest('hex').slice(0, 16)
+
+/**
+ * Kill stale instance that used the SAME bot token (identified by token hash).
+ * Different bots (different tokens, different STATE_DIRs) are never touched.
+ */
+function killOldInstance(): void {
+  try {
+    const raw = readFileSync(PID_FILE, 'utf8')
+    const entry = JSON.parse(raw) as { pid: number; tokenHash: string }
+    if (entry.tokenHash !== TOKEN_HASH || entry.pid === process.pid) return
+
+    // Check if old process is still alive
+    try { process.kill(entry.pid, 0) } catch { return } // already dead
+
+    process.stderr.write(`telegram channel: killing stale instance PID ${entry.pid}\n`)
+    try { process.kill(entry.pid, 'SIGTERM') } catch { return }
+
+    // Give 2s for graceful shutdown, then force-kill
+    const deadline = Date.now() + 2000
+    while (Date.now() < deadline) {
+      try { process.kill(entry.pid, 0) } catch { return } // dead
+      Bun.sleepSync(100)
+    }
+    try {
+      process.kill(entry.pid, 'SIGKILL')
+      process.stderr.write(`telegram channel: force-killed stale instance PID ${entry.pid}\n`)
+    } catch {}
+  } catch {} // no PID file or parse error — nothing to kill
+}
+
+function writePidFile(): void {
+  mkdirSync(STATE_DIR, { recursive: true, mode: 0o700 })
+  const entry = { pid: process.pid, tokenHash: TOKEN_HASH, startedAt: new Date().toISOString() }
+  writeFileSync(PID_FILE, JSON.stringify(entry) + '\n', { mode: 0o600 })
+}
+
+function removePidFile(): void {
+  try { rmSync(PID_FILE, { force: true }) } catch {}
+}
 
