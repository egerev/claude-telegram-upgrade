+/**
+ * Run a command asynchronously using Bun.spawn. Returns stdout as string.
+ */
+async function runAsync(cmd: string, args: string[], timeout = 120_000): Promise<string> {
+  const proc = Bun.spawn([cmd, ...args], { stdout: 'pipe', stderr: 'pipe' })
+  const timer = setTimeout(() => proc.kill(), timeout)
+  const [stdout, stderr, exitCode] = await Promise.all([
+    new Response(proc.stdout).text(),
+    new Response(proc.stderr).text(),
+    proc.exited,
+  ])
+  clearTimeout(timer)
+  if (exitCode !== 0) throw new Error(`${cmd} exited ${exitCode}: ${stderr.slice(0, 200)}`)
+  return stdout
+}
+
+/**
+ * Check if a command exists on the system.
+ */
+async function commandExists(cmd: string): Promise<boolean> {
+  try {
+    const proc = Bun.spawn(['sh', '-c', `command -v ${cmd}`], { stdout: 'pipe', stderr: 'pipe' })
+    return (await proc.exited) === 0
+  } catch { return false }
+}
