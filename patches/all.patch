+/**
+ * Transcribe a voice message using locally installed Whisper (async).
+ * Tries mlx_whisper (macOS Apple Silicon) first, then whisper-cpp.
+ * Env: TELEGRAM_WHISPER_MODEL (default: mlx-community/whisper-small-mlx),
+ *      TELEGRAM_WHISPER_LANGUAGE (optional, e.g. "ru").
+ */
+async function transcribeVoice(ogaPath: string): Promise<string | null> {
+  const wavPath = ogaPath.replace(/\.[^.]+$/, '.wav')
+  try {
+    // Convert .oga to 16kHz mono .wav
+    try {
+      await runAsync('ffmpeg', ['-i', ogaPath, '-ar', '16000', '-ac', '1', '-c:a', 'pcm_s16le', wavPath, '-y'], 30_000)
+    } catch (e: any) {
+      process.stderr.write(`telegram channel: ffmpeg conversion failed: ${e.message}\n`)
+      return null
+    }
+    const model = process.env.TELEGRAM_WHISPER_MODEL
+    const lang = process.env.TELEGRAM_WHISPER_LANGUAGE
+    // mlx_whisper (macOS Apple Silicon) — writes <basename>.txt to output dir
+    if (await commandExists('mlx_whisper')) {
+      try {
+        await runAsync('mlx_whisper', [
+          '--model', model ?? 'mlx-community/whisper-small-mlx',
+          '--output-format', 'txt', '--output-dir', INBOX_DIR,
+          ...(lang ? ['--language', lang] : []), wavPath,
+        ], 120_000)
+        const txtFile = join(INBOX_DIR, wavPath.split('/').pop()!.replace(/\.wav$/, '.txt'))
+        const text = readFileSync(txtFile, 'utf8').trim()
+        try { rmSync(txtFile, { force: true }) } catch {}
+        return text || null
+      } catch (e: any) {
+        process.stderr.write(`telegram channel: mlx_whisper failed: ${e.message}\n`)
+      }
+    }
+    // whisper-cpp (Linux / Intel Mac) — outputs to stdout
+    if (await commandExists('whisper-cpp')) {
+      if (!model) {
+        process.stderr.write('telegram channel: whisper-cpp needs TELEGRAM_WHISPER_MODEL (path to .bin)\n')
+        return null
+      }
+      try {
+        const out = await runAsync('whisper-cpp', [
+          '-m', model, '-f', wavPath, '--no-timestamps',
+          ...(lang ? ['-l', lang] : []),
+        ], 120_000)
+        return out.trim() || null
+      } catch (e: any) {
+        process.stderr.write(`telegram channel: transcription failed: ${e.message}\n`)
+        return null
+      }
+    }
+    process.stderr.write('telegram channel: no whisper found (install mlx-whisper or whisper-cpp)\n')
+    return null
+  } finally {
+    try { rmSync(wavPath, { force: true }) } catch {}
+  }
+}
